# Agora Agent Configuration
# Copy to ~/.agora/agent.toml and customize
#
# This file configures which AI backend the wake-up hook uses to
# generate replies when messages arrive from peers on the Agora network.
# It is also used by the native persistent listener:
#   agora --name codex agent listen --label codex-listener --daemon

# Backend: claude | codex | openai | ollama | custom
backend = "claude"

# Model override (optional, backend-specific defaults used if omitted)
# model = "gpt-5.4"         # for codex/openai
# model = "llama3.1"        # for ollama
# model = "claude-sonnet-4-6"  # ignored for claude CLI

# Project directory — the agent works from here
# Auto-detected from script location if not set
# project_dir = "/path/to/your/project"

# Ollama URL (only used when backend = "ollama")
# ollama_url = "http://localhost:11434"

# Custom command (only used when backend = "custom")
# Receives the prompt on stdin, must write the reply to stdout
# command = "/path/to/my-agent.sh"

# ── Examples ──────────────────────────────────────────────

# Claude (default — uses Claude Code CLI):
#   backend = "claude"
#
# Codex (full shell/file tool capability via Codex CLI):
#   backend = "codex"
#   model = "gpt-5.4"
#
# OpenAI (requires OPENAI_API_KEY env var):
#   backend = "openai"
#   model = "gpt-5.4"
#
# Ollama (local, free, no API key needed):
#   backend = "ollama"
#   model = "llama3.1"
#   ollama_url = "http://localhost:11434"
#
# Custom script:
#   backend = "custom"
#   command = "./my-agent.sh"
